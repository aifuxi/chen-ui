{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "chen-serif-prose",
  "title": "Chen Serif Prose",
  "description": "Installs the Chen Serif markdown prose utility class for editorial content.",
  "registryDependencies": [
    "chen-serif-theme"
  ],
  "css": {
    "@layer components": {
      ".chen-serif-prose :is(h1)": {
        "font-family": "var(--font-serif)",
        "font-size": "clamp(2.25rem, 5vw, 3rem)",
        "font-weight": "600",
        "letter-spacing": "-0.02em"
      },
      ".chen-serif-prose :is(h2)": {
        "margin-top": "2.5rem",
        "font-family": "var(--font-serif)",
        "font-size": "1.875rem",
        "font-weight": "600",
        "letter-spacing": "-0.02em"
      },
      ".chen-serif-prose :is(h3)": {
        "margin-top": "2rem",
        "font-family": "var(--font-serif)",
        "font-size": "1.5rem",
        "font-weight": "600"
      },
      ".chen-serif-prose :is(p)": {
        "font-size": "clamp(0.875rem, 0.82rem + 0.24vw, 1rem)",
        "line-height": "1.75",
        "color": "var(--muted-foreground)"
      },
      ".chen-serif-prose :is(a)": {
        "color": "var(--primary)",
        "text-underline-offset": "4px"
      },
      ".chen-serif-prose :is(a:hover)": {
        "text-decoration": "underline"
      },
      ".chen-serif-prose :is(ul)": {
        "margin-left": "1.25rem",
        "list-style-type": "disc",
        "font-size": "0.875rem",
        "color": "var(--muted-foreground)"
      },
      ".chen-serif-prose :is(ol)": {
        "margin-left": "1.25rem",
        "list-style-type": "decimal",
        "font-size": "0.875rem",
        "color": "var(--muted-foreground)"
      },
      ".chen-serif-prose :is(li)": {
        "padding-left": "0.25rem"
      },
      ".chen-serif-prose :is(li + li)": {
        "margin-top": "0.5rem"
      },
      ".chen-serif-prose :is(h1, h2, h3, h4, h5, h6, p, li, blockquote, td, th) > code": {
        "border-radius": "var(--radius-sm)",
        "border": "1px solid rgba(255, 255, 255, 0.1)",
        "background": "rgba(255, 255, 255, 0.05)",
        "padding": "0.125rem 0.375rem",
        "font-family": "var(--font-mono)",
        "font-size": "0.85em",
        "color": "var(--foreground)"
      },
      ".chen-serif-prose :is(blockquote)": {
        "border-left": "2px solid var(--primary)",
        "padding-left": "1rem",
        "font-family": "var(--font-serif)",
        "font-size": "1.25rem",
        "font-style": "italic",
        "color": "color-mix(in srgb, var(--foreground) 90%, transparent)"
      },
      ".chen-serif-prose :is(table)": {
        "width": "100%",
        "border-collapse": "collapse",
        "text-align": "left"
      },
      ".chen-serif-prose :is(th)": {
        "border-bottom": "1px solid rgba(255, 255, 255, 0.1)",
        "padding": "0.75rem 1rem",
        "font-family": "var(--font-mono)",
        "font-size": "11px",
        "font-weight": "500",
        "text-transform": "uppercase",
        "letter-spacing": "0.16em",
        "color": "var(--muted-foreground)"
      },
      ".chen-serif-prose :is(td)": {
        "border-bottom": "1px solid rgba(255, 255, 255, 0.05)",
        "padding": "0.75rem 1rem",
        "font-size": "0.875rem",
        "color": "var(--foreground)"
      }
    }
  },
  "type": "registry:style"
}